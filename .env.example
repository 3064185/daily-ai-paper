# ── LLM (OpenAI-compatible) ──
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# For DeepSeek (OpenAI-compatible), set:
# OPENAI_API_KEY=your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# ── Email (QQ SMTP) ──
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-address@qq.com
EMAIL_PASSWORD=SMTP_AUTHORIZATION_CODE
EMAIL_TO=recipient@example.com

# ── API Keys (optional) ──
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=your-email@example.com

# ── Timeouts & limits ──
REQUEST_TIMEOUT=25
MAX_PAPERS_PER_SOURCE=30
DOWNLOAD_OPEN_ACCESS_PDFS=true
MAX_PDF_ATTACHMENT_MB=12
MAX_EMAIL_ATTACHMENT_MB=18

# ── Network ──
USE_SYSTEM_PROXY=false
