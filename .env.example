# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email (QQ SMTP) ──
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your-address@qq.com
EMAIL_PASSWORD=SMTP_AUTHORIZATION_CODE
EMAIL_TO=recipient@example.com

# ── API Keys (optional) ──
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_EMAIL=your-email@example.com

# ── Timeouts & limits ──
REQUEST_TIMEOUT=25
MAX_PAPERS_PER_SOURCE=30
DOWNLOAD_OPEN_ACCESS_PDFS=true
MAX_PDF_ATTACHMENT_MB=12
MAX_EMAIL_ATTACHMENT_MB=18

# ── Network ──
USE_SYSTEM_PROXY=false
